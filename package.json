{
  "name": "basalt-mcp",
  "version": "0.2.0",
  "description": "Secure MCP server with modular tool support. Obsidian vault tools included.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "basalt-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "keywords": [
    "mcp",
    "obsidian",
    "vault",
    "security",
    "git"
  ],
  "license": "MIT",
  "author": "cmillstead",
  "repository": {
    "type": "git",
    "url": "https://github.com/cmillstead/basalt-mcp.git"
  },
  "homepage": "https://github.com/cmillstead/basalt-mcp",
  "bugs": {
    "url": "https://github.com/cmillstead/basalt-mcp/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "glob": "13.0.6",
    "re2": "1.23.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
